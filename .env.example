# Copy this file to ".env.local" for local development, and set the same
# variables in your deployment environment (Coolify → Environment, or Docker env)
# for production.

# Your Anthropic API key — get one at https://console.anthropic.com/
# This stays on the SERVER and is never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED for deployed apps: an access code protecting the AI endpoints, so
# strangers can't burn your Anthropic credits. A production deployment FAILS
# CLOSED without this — every AI route returns an error until it's set. Pick any
# code you can type on your phone — the app asks for it once per device and
# remembers it. Leave blank only for local development.
APP_SECRET=

# ── Phase 2: eBay posting (not required for sorting/writing listings) ─────────
# From your eBay keyset at https://developer.ebay.com/. You can reuse your
# existing keyset's App ID + Cert ID, as long as you create a NEW, dedicated
# RuName for this web app (so the Python lister's RuName stays untouched).
# Leave these blank until you're ready for posting.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=
# Random secret used to encrypt your stored eBay connection. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Your deployed app URL, used for the OAuth redirect (e.g. https://your-app.example.com)
APP_URL=
# Optional: your ZIP code. Only used once, to create an eBay inventory location
# if your account doesn't already have one. Defaults to 10001 if unset.
EBAY_LOCATION_POSTAL_CODE=

# Optional: default package weight/size sent to eBay so CALCULATED-shipping
# policies can publish (eBay returns error 25020 if weight is missing). Weight is
# in ounces (16 = 1 lb); dimensions are in inches. You can still edit weight/size
# on each listing in eBay afterward. Defaults: 16 oz, 12 x 9 x 3 in.
EBAY_DEFAULT_PACKAGE_WEIGHT_OZ=16
EBAY_DEFAULT_PACKAGE_LENGTH_IN=12
EBAY_DEFAULT_PACKAGE_WIDTH_IN=9
EBAY_DEFAULT_PACKAGE_HEIGHT_IN=3
